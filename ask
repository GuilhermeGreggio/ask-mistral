#!/bin/bash

# ask - Simple Mistral API CLI tool
# Usage: ask [OPTIONS] [PROMPT]

set -euo pipefail

# Check for API key
if [ -z "${MISTRAL_API_KEY:-}" ]; then
    echo "Error: MISTRAL_API_KEY environment variable is not set" >&2
    exit 1
fi

# Model shortcuts function
get_model() {
    case "$1" in
        m) echo "devstral-medium-latest" ;;
        s) echo "devstral-small-latest" ;;
    esac
}

# Default values
MODEL="devstral-medium-latest"
SYSTEM_PROMPT=""
PROMPT=""
STREAMING=false
NO_SYSTEM=false
DEBUG=false

# Default system prompt (direct answers)
DEFAULT_PROMPT="You are a direct answer engine. Output ONLY the requested information.

For commands: Output executable syntax only. No explanations, no comments.
For questions: Output the answer only. No context, no elaboration.

Rules:
- If asked for a command, provide ONLY the command
- If asked a question, provide ONLY the answer
- Never include markdown formatting or code blocks
- Never add explanatory text before or after
- Assume output will be piped or executed directly
- For multi-step commands, use && or ; to chain them
- Make commands robust and handle edge cases silently"

# Function to show help
show_help() {
    cat << EOF
ask - Query AI models via Mistral API

Usage: ask [OPTIONS] [PROMPT]

Options:
  -m          Use devstral-medium-latest (default)
  -s          Use devstral-small-latest
  -m MODEL    Use custom model name
  -r          Disable system prompt (raw model behavior)
  --stream    Enable streaming output
  --system    Set system prompt for the conversation
  --debug     Enable debug output
  --test      Run connectivity test
  -h, --help  Show this help message

Examples:
  ask "Write a hello world in Python"
  ask -s "Explain quantum computing"
  ask -m devstral-medium-latest "What is 2+2?"
  echo "Fix this code" | ask
  ask --system "You are a pirate" "Tell me about sailing"
  ask --test  Test API connectivity

EOF
    exit 0
}

# Function to test API connectivity
test_connectivity() {
    echo "Testing Mistral API connectivity..."
    echo "API Key: ${MISTRAL_API_KEY:0:10}..." >&2
    
    TEST_PAYLOAD='{
        "model": "devstral-small-latest",
        "messages": [{"role":"user","content":"test"}],
        "stream": false
    }'
    
    echo "Sending test request to https://api.mistral.ai/v1/chat/completions" >&2
    
    response=$(curl -sS -w "\n%{http_code}" "https://api.mistral.ai/v1/chat/completions" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer $MISTRAL_API_KEY" \
      -d "$TEST_PAYLOAD" 2>&1)
    
    http_code=$(echo "$response" | tail -1)
    body=$(echo "$response" | sed '$d')
    
    echo "HTTP Status: $http_code" >&2
    echo "Response:" >&2
    echo "$body" | jq . 2>/dev/null || echo "$body" >&2
    
    if [ "$http_code" = "200" ]; then
        echo "✓ API connectivity test passed!" >&2
        exit 0
    else
        echo "✗ API connectivity test failed with status $http_code" >&2
        exit 1
    fi
}

# Parse command line arguments
while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help) show_help ;;
        --test) test_connectivity ;;
        --debug)
            DEBUG=true
            shift ;;
        -[ms])
            MODEL="$(get_model "${1:1}")"
            shift ;;
        -m)
            MODEL="${2:?Error: -m requires a model name}"
            shift 2 ;;
        -r)
            NO_SYSTEM=true
            shift ;;
        --stream)
            STREAMING=true
            shift ;;
        --system)
            SYSTEM_PROMPT="${2:?Error: --system requires a prompt}"
            shift 2 ;;
        *)
            PROMPT="$*"
            break ;;
    esac
done

# If no prompt provided as argument, read from stdin
if [ -z "$PROMPT" ]; then
    if [ -t 0 ]; then
        echo "Error: No prompt provided. Use 'ask -h' for help." >&2
        exit 1
    fi
    # Read all stdin, preserving multi-line format
    PROMPT=$(cat)
fi

# Apply default system prompt unless disabled or custom prompt provided
if [ "$NO_SYSTEM" = false ] && [ -z "$SYSTEM_PROMPT" ]; then
    SYSTEM_PROMPT="$DEFAULT_PROMPT"
fi

# Build messages array with proper JSON escaping
if [ -n "$SYSTEM_PROMPT" ]; then
    MESSAGES='[{"role":"system","content":'"$(printf '%s' "$SYSTEM_PROMPT" | jq -Rs .)"'},{"role":"user","content":'"$(printf '%s' "$PROMPT" | jq -Rs .)"'}]'
else
    MESSAGES='[{"role":"user","content":'"$(printf '%s' "$PROMPT" | jq -Rs .)"'}]'
fi

# Record start time
START_TIME=$(date +%s.%N)

# Build JSON payload once
JSON_PAYLOAD='{
    "model": "'"$MODEL"'",
    "messages": '"$MESSAGES"',
    "stream": '$([ "$STREAMING" = true ] && echo true || echo false)'
}'

API_URL="https://api.mistral.ai/v1/chat/completions"

# Debug output
if [ "$DEBUG" = true ]; then
    echo "=== DEBUG INFO ===" >&2
    echo "Model: $MODEL" >&2
    echo "API URL: $API_URL" >&2
    echo "Streaming: $STREAMING" >&2
    echo "API Key (first 10 chars): ${MISTRAL_API_KEY:0:10}..." >&2
    echo "Payload: $JSON_PAYLOAD" >&2
    echo "=================" >&2
fi

# Add newline before answer
echo

# Make API request
if [ "$STREAMING" = true ]; then
    # Streaming mode
    if [ "$DEBUG" = true ]; then
        echo "Making streaming request..." >&2
    fi
    curl -sS "$API_URL" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer $MISTRAL_API_KEY" \
      -d "$JSON_PAYLOAD" 2>&1 | while IFS= read -r line; do
        # Check for errors
        if echo "$line" | grep -q '"error"'; then
            echo "Error: $(echo "$line" | jq -r '.error.message // .error // "Unknown error"')" >&2
            exit 1
        fi

        # Process SSE data lines
        if [[ "$line" == data:* ]]; then
            json="${line#data: }"
            [ "$json" = "" ] || [ "$json" = "[DONE]" ] && continue

            content=$(echo "$json" | jq -r '.choices[0].delta.content // ""' 2>/dev/null)
            [ -n "$content" ] && printf '%s' "$content"
        fi
    done
    echo

    # Show metadata
    ELAPSED=$(echo "$(date +%s.%N) - $START_TIME" | bc 2>/dev/null | xargs printf "%.2f" 2>/dev/null || echo "0.00")
    echo
    echo "[$MODEL - ${ELAPSED}s]" >&2
else
    # Non-streaming mode
    if [ "$DEBUG" = true ]; then
        echo "Making non-streaming request with 30s timeout..." >&2
    fi
    
    response=$(curl -sS --max-time 30 "$API_URL" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer $MISTRAL_API_KEY" \
      -d "$JSON_PAYLOAD" 2>&1)
    
    curl_exit=$?
    
    if [ "$DEBUG" = true ]; then
        echo "Curl exit code: $curl_exit" >&2
        echo "Response length: ${#response}" >&2
        echo "Response (first 500 chars): ${response:0:500}" >&2
    fi
    
    if [ $curl_exit -ne 0 ]; then
        echo "Error: curl request failed with exit code $curl_exit" >&2
        echo "$response" >&2
        exit 1
    fi

    # Check for errors
    if echo "$response" | grep -q '"error"'; then
        echo "Error: $(echo "$response" | jq -r '.error.message // .error // "Unknown error"')" >&2
        exit 1
    fi

    # Extract and print content
    echo "$response" | jq -r '.choices[0].message.content // "No response received"'

    # Show metadata
    ELAPSED=$(echo "$(date +%s.%N) - $START_TIME" | bc 2>/dev/null | xargs printf "%.2f" 2>/dev/null || echo "0.00")
    TOKENS=$(echo "$response" | jq -r '.usage.completion_tokens // 0')
    TPS=$(echo "scale=1; $TOKENS / $ELAPSED" | bc 2>/dev/null || echo "0.0")

    echo
    echo "[$MODEL - ${ELAPSED}s - ${TPS} tok/s]" >&2
fi
